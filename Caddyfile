# ============================================================
# Caddyfile - PT Agung Denko
# Domain  : agungdenko.asia
# Server  : 147.139.193.24 (Alibaba Cloud Linux)
# Dir     : /opt/dws-portal
# PHP-FPM : 127.0.0.1:9000 (port, bukan socket)
# ============================================================

# Redirect www → non-www
www.agungdenko.asia {
	redir https://agungdenko.asia{uri} permanent
}

# Frontend - Static HTML
agungdenko.asia {
	root * /opt/dws-portal/dws-nextjs

	file_server

	# Fallback ke index.html
	try_files {path} /index.html

	# Cache asset statis 30 hari
	@static path *.css *.js *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp
	header @static Cache-Control "public, max-age=2592000, no-transform"

	# Security Headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "no-referrer-when-downgrade"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}

	encode gzip

	log {
		output file /var/log/caddy/agungdenko-access.log
		format json
	}
}

# Backend API - Laravel + PHP-FPM
api.agungdenko.asia {
	root * /opt/dws-portal/backend/public

	# PHP-FPM via TCP port 9000 (Alibaba Cloud Linux)
	php_fastcgi 127.0.0.1:9000

	file_server

	# Cache asset statis
	@static path *.css *.js *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp
	header @static Cache-Control "public, max-age=2592000, no-transform"

	# Security Headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-X-Powered-By
	}

	# Tolak akses file tersembunyi
	@hidden path /.*
	respond @hidden 403

	# Upload limit 25MB
	request_body {
		max_size 25MB
	}

	encode gzip

	log {
		output file /var/log/caddy/api-agungdenko-access.log
		format json
	}
}
