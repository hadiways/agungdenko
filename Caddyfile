# ============================================================
# Caddyfile - PT Agung Denko
# Domain  : agungdenko.asia
# Server  : 147.139.193.24 (Alibaba Cloud Linux)
# Dir     : /opt/dws-portal
# PHP-FPM : 127.0.0.1:9000 (port, bukan socket)
# ============================================================

# Redirect www → non-www
www.agungdenko.asia {
	redir https://agungdenko.asia{uri} permanent
}

# Frontend + Path-based API (same domain, no CORS)
agungdenko.asia {

	# ── Backend API via path /api/* ─────────────────────────
	route /api/* {
		root * /opt/dws-portal/backend/public
		php_fastcgi 127.0.0.1:9000
		request_body { max_size 25MB }
	}

	# ── Laravel Storage ──────────────────────────────────────
	route /storage/* {
		root * /opt/dws-portal/backend/public
		file_server
	}

	# ── Sanctum CSRF Cookie ──────────────────────────────────
	route /sanctum/* {
		root * /opt/dws-portal/backend/public
		php_fastcgi 127.0.0.1:9000
	}

	# ── Dynamic sitemap ──────────────────────────────────────
	route /sitemap.xml {
		root * /opt/dws-portal/backend/public
		rewrite * /sitemap.php
		php_fastcgi 127.0.0.1:9000
	}

	# ── Frontend Static Files ────────────────────────────────
	root * /opt/dws-portal/dws-nextjs/out
	file_server
	try_files {path} {path}.html {path}/index.html /index.html

	# Cache asset statis 30 hari
	@static path *.css *.js *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp
	header @static Cache-Control "public, max-age=2592000, no-transform"

	# Security Headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		X-XSS-Protection "1; mode=block"
		Referrer-Policy "no-referrer-when-downgrade"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}

	encode gzip

	log {
		output file /var/log/caddy/agungdenko-access.log
		format json
	}
}

# Backend API - Laravel + PHP-FPM
api.agungdenko.asia {
	root * /opt/dws-portal/backend/public

	# PHP-FPM via TCP port 9000 (Alibaba Cloud Linux)
	php_fastcgi 127.0.0.1:9000

	file_server

	# Cache asset statis
	@static path *.css *.js *.jpg *.jpeg *.png *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp
	header @static Cache-Control "public, max-age=2592000, no-transform"

	# Security Headers
	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-X-Powered-By
	}

	# Tolak akses file tersembunyi
	@hidden path /.*
	respond @hidden 403

	# Upload limit 25MB
	request_body {
		max_size 25MB
	}

	encode gzip

	log {
		output file /var/log/caddy/api-agungdenko-access.log
		format json
	}
}

# Sanity Studio CMS - Editor Dashboard
cms.agungdenko.asia {
	root * /opt/dws-portal/studio/dist
	file_server
	try_files {path} {path}/ /index.html
	encode gzip
	log {
		output file /var/log/caddy/cms-agungdenko-access.log
		format json
	}
}
